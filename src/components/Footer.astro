---
import Logo from "./icons/Logo.astro"
import Github from "../components/icons/Github.astro"
import Dribbble from "../components/icons/Dribbble.astro"
import Linkedin from "../components/icons/Linkedin.astro"
import Codepen from "../components/icons/Codepen.astro"

export const currentYear = new Date().getFullYear()
---

<footer class="region" data-region="footer">
  <a href="/" aria-label="Go to the home page">
    <Logo />
  </a>
  <ul role="list">
    <li>
      <a
        href="https://github.com/ToniMaunde"
        target="_blank"
        rel="noreferrer"
        aria-label="Milton David's Github profile"
      >
        <Github />
        <span>Github</span>
      </a>
    </li>
    <li>
      <a
        href="https://codepen.io/ToniMaunde"
        target="_blank"
        rel="noreferrer"
        aria-label="Milton David's Codepen profile"
      >
        <Codepen />
        <span>Codepen</span>
      </a>
    </li>
    <li>
      <a
        href="https://dribbble.com/ToniMaunde"
        target="_blank"
        rel="noreferrer"
        aria-label="Milton David's Dribbble profile"
      >
        <Dribbble />
        <span>Dribbble</span>
      </a>
    </li>
    <li>
      <a
        href="https://linkedin.com/in/toniMaunde"
        target="_blank"
        rel="noreferrer"
        aria-label="Milton David's LinkedIn profile"
      >
        <Linkedin />
        <span>Linkedin</span>
      </a>
    </li>
  </ul>
  <p>
    ©2021-{currentYear} Milton David. All Rights Reserved.
  </p>
</footer>
